NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Supabase PostgreSQL connection string used by Prisma.
DATABASE_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:PASSWORD@HOST:5432/postgres

# Required only by the administrative Auth seed script.
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Transactional outbox worker. Events are published to the console in this exercise.
OUTBOX_POLL_INTERVAL_MS=1000
OUTBOX_BATCH_SIZE=100
OUTBOX_MAX_RETRIES=5
PAYMENT_NOTIFICATION_TOPIC=payment-succeeded

# Subscription expiration worker.
SUBSCRIPTION_EXPIRATION_POLL_INTERVAL_MS=60000
SUBSCRIPTION_EXPIRATION_BATCH_SIZE=100
